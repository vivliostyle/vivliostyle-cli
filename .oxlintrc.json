{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "vitest"],
  "categories": {
    "correctness": "error",
    "pedantic": "error",
    "perf": "error",
    "suspicious": "error"
  },
  "rules": {
    // Correctness Rules
    "no-unused-vars": [
      "error",
      {
        "args": "after-used",
        "argsIgnorePattern": "^_",
        "caughtErrors": "none",
        "varsIgnorePattern": "^_",
        "destructuredArrayIgnorePattern": "^_"
      }
    ],
    // Restriction Rules
    "no-explicit-any": "error",
    "explicit-module-boundary-types": "error",
    "no-non-null-assertion": "error",
    "no-dynamic-delete": "error",
    "no-import-type-side-effects": "error",
    "no-invalid-void-type": "error",
    "prefer-number-properties": "error",
    "prefer-node-protocol": "error",
    "no-param-reassign": "error",
    "vitest/expect-expect": [
      "error",
      {
        "assertFunctionNames": [
          "expect",
          "expectTypeOf",
          "**.expect",
          "**.expectTypeOf"
        ]
      }
    ],
    // Pedantic Rules
    "max-classes-per-file": "off",
    "max-lines": "off",
    "max-lines-per-function": "off",
    "no-inline-comments": ["error", { "ignorePattern": "@vite-ignore" }],
    "no-warning-comments": "warn",
    "require-unicode-regexp": ["error", { "requireFlag": "v" }],
    "prefer-number-coercion": "off",
    // Perf Rules
    "no-await-in-loop": "off",
    // Suspicious Rules
    "consistent-function-scoping": "off",
    "no-shadow": ["error", { "allow": ["_"] }],
    // Style Rules
    "consistent-type-imports": ["error", { "disallowTypeAnnotations": false }],
    "curly": "error",
    "prefer-const": ["error", { "destructuring": "all" }]
  },
  "overrides": [
    {
      "files": ["tests/**"],
      "rules": {
        "no-explicit-any": "off",
        "no-non-null-assertion": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist",
    "tmp",
    "coverage",
    "examples",
    "templates",
    "docs",
    "tests/fixtures",
    "src/schema/publication.schema.ts",
    "**/*.astro"
  ]
}
