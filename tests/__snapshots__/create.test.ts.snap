  /* ドキュメントタイトルを左上に表示 */
  /* --vs-page--mbox-content-top-left: env(pub-title); */

  /* 章タイトルを右上に表示 */
  /* --vs-page--mbox-content-top-right: env(doc-title); */

  /* ===================================
   * コードブロック（Prism.js）
   * 注: Prism.js CSS モジュールを追加でインクルードするか、
   * それを含むテーマを使用する必要があります（例: @vivliostyle/theme-techbook）
   * =================================== */
}
