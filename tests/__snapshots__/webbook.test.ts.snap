// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`copy webpub assets properly 1`] = `
"output/
тФЬтФА doc.html
тФЬтФА publication.json
тФФтФА themes/
   тФФтФА node_modules/
      тФЬтФА @org/
      тФВ  тФФтФА themeB/
      тФВ     тФФтФА theme.css
      тФФтФА themeA/
         тФФтФА theme.css"
`;

exports[`generate webpub from a data URI input > html 1`] = `
"<!doctype html>
<html lang=\\"en\\"
  ><head
    ><meta charset=\\"UTF-8\\" /><title></title
    ><link
      rel=\\"publication\\"
      type=\\"application/ld+json\\"
      href=\\"publication.json\\" /></head
  ><body
    >Hi</body
  ></html
>
"
`;

exports[`generate webpub from a data URI input > tree 1`] = `
"output/
тФЬтФА index.html
тФФтФА publication.json"
`;

exports[`generate webpub from a plain HTML > entry 1`] = `
"<!doctype html>
<html lang=\\"ja\\"
  ><head>
    <link rel=\\"stylesheet\\" type=\\"text/css\\" href=\\"style.css\\" />
    <title>Doc title</title>
    <link rel=\\"publication\\" type=\\"application/ld+json\\" href=\\"publication.json\\"
  /></head>
  <body> </body
></html>
"
`;

exports[`generate webpub from a plain HTML > manifest 1`] = `
Object {
  "@context": Array [
    "https://schema.org",
    "https://www.w3.org/ns/pub-context",
  ],
  "conformsTo": "https://github.com/vivliostyle/vivliostyle-cli",
