`;

exports[`generate webpub from a remote HTML document > tree 1`] = `
"output/
тФЬтФА publication.json
тФФтФА remote/
   тФЬтФА foo bar%/
   тФВ  тФФтФА escape check%.html
   тФФтФА уБВ/
      тФФтФА цЧецЬмшкЮ.css"
`;

exports[`generate webpub from a single-document publication > entry 1`] = `
"<html lang=\\"en\\">
  <head>
    <title>Document with toc</title>
    <link rel=\\"publication\\" href=\\"#wp_manifest\\" />
    <script type=\\"application/ld+json\\" id=\\"wp_manifest\\">
      {
        \\"@context\\": [\\"https://schema.org\\", \\"https://www.w3.org/ns/wp-context\\"],
        \\"conformsTo\\": \\"yuno\\",
        \\"resources\\": [\\"assets/%E6%97%A5%E6%9C%AC%E8%AA%9E.svg\\"],
        \\"readingOrder\\": [
          \\"#foo\\",
          \\"../bar.html\\",
          \\"subdir/index.html\\",
          \\"escape%20check%25.html\\"
        ]
      }
    </script>
  </head>
  <body> </body>
</html>
"
`;

exports[`generate webpub from a single-document publication > tree 1`] = `
"output/
тФЬтФА assets/
тФВ  тФЬтФА subdir.css
тФВ  тФФтФА цЧецЬмшкЮ.svg
тФЬтФА escape check%.html
тФЬтФА subdir/
тФВ  тФФтФА index.html
тФФтФА webbook.html"
`;

exports[`generate webpub from remote HTML documents with publication manifest > tree 1`] = `
"output/
тФЬтФА assets/
тФВ  тФФтФА цЧецЬмшкЮ.png
тФФтФА remote/
   тФЬтФА dir/
   тФВ  тФЬтФА escape check%.html
   тФВ  тФФтФА index.html
   тФФтФА publication.json"
`;

