exports[`generate webpub from vivliostyle.config.js > manifest 1`] = `
Object {
  "@context": Array [
    "https://schema.org",
    "https://www.w3.org/ns/pub-context",
  ],
  "conformsTo": "https://github.com/vivliostyle/vivliostyle-cli",
  "links": Array [],
  "name": "output",
  "readingOrder": Array [
    Object {
      "rel": "cover",
      "type": "LinkedResource",
      "url": "cover.html",
    },
    Object {
      "name": "Table of Contents",
      "rel": "contents",
      "type": "LinkedResource",
      "url": "index.html",
    },
    Object {
      "url": "doc/one.html",
    },
    Object {
      "url": "doc/two.html",
    },
    Object {
      "url": "doc/escape%20check%25.html",
    },
  ],
  "readingProgression": "rtl",
  "resources": Array [
    Object {
      "encodingFormat": "image/png",
      "name": "Cover image",
      "rel": "cover",
      "url": "cover.png",
    },
    "style%20sheet.css",
    "themes/node_modules/mytheme/%25style%25.css",
  ],
  "type": "Book",
}
`;

exports[`generate webpub from vivliostyle.config.js > tree 1`] = `
"output/
тФЬтФА cover.html
тФЬтФА cover.png
тФЬтФА doc/
тФВ  тФЬтФА escape check%.html
тФВ  тФЬтФА one.html
тФВ  тФФтФА two.html
тФЬтФА index.html
тФЬтФА publication.json
тФЬтФА style sheet.css
тФФтФА themes/
   тФФтФА node_modules/
      тФФтФА mytheme/
         тФФтФА %style%.css"
`;

exports[`generate webpub with complex copyAsset settings > tree 1`] = `
"output/
тФЬтФА assetA.jxl
тФЬтФА doc.html
тФЬтФА node_modules/
тФВ  тФФтФА pkgB/
