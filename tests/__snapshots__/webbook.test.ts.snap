    Object {
      "url": "webbook.html",
    },
  ],
  "resources": Array [
    "style.css",
  ],
  "type": "Book",
}
`;

exports[`generate webpub from a plain HTML > tree 1`] = `
"output/
тФЬтФА publication.json
тФЬтФА style.css
тФФтФА webbook.html"
`;

exports[`generate webpub from a remote HTML document > entry 1`] = `
"<html lang=\\"en\\"
  ><head>
    <title>Document</title>
    <link
      rel=\\"stylesheet\\"
      type=\\"text/css\\"
      href=\\"../%E3%81%82/%E6%97%A5%E6%9C%AC%E8%AA%9E.css\\" />
    <link
      rel=\\"publication\\"
      type=\\"application/ld+json\\"
      href=\\"../../publication.json\\"
  /></head>
  <body> </body
></html>
"
`;

exports[`generate webpub from a remote HTML document > manifest 1`] = `
Object {
  "@context": Array [
    "https://schema.org",
    "https://www.w3.org/ns/pub-context",
  ],
  "conformsTo": "https://github.com/vivliostyle/vivliostyle-cli",
  "inLanguage": "en",
  "links": Array [],
  "name": "Document",
  "readingOrder": Array [
    Object {
      "url": "remote/foo%20bar%25/escape%20check%25.html",
    },
  ],
